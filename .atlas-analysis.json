  "projectType": "saas",
  "projectName": "VShop",
  "projectDescription": "A React Native mobile app for Valorant players to check their in-game shop, Night Market, bundles, accessories, profile, and manage a skin wishlist with background notifications.",
  "theme": "almond",
  "primaryColor": "#040404",
  "lightColor": null,

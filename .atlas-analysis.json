  "keyFeatures": [
    "View daily Valorant skin shop with countdown timer",
    "Night Market discounted skin offers",
    "Featured bundle browsing",
    "Accessory shop (buddies, sprays, player cards, titles)",
    "Skin gallery with wishlist management",
    "Background notifications when wishlisted skins appear in shop",
    "Player profile with XP progress and currency balances",
    "Multi-region support (EU, NA, AP, KR)",
    "Internationalization (i18next) with Weblate translations",
    "Donator/supporter features via Stripe payments",
    "Runs entirely on-device — credentials sent directly to Riot servers"
  ],
  "publicApiSurface": [
    "getEntitlementsToken(accessToken)",
    "getUserId(accessToken)",
    "getUsername(accessToken, entitlementsToken, userId, region)",
    "getShop(accessToken, entitlementsToken, region, userId)",
    "parseShop(shop: StorefrontResponse)",
    "getBalances(accessToken, entitlementsToken, region, userId)",
    "getProgress(accessToken, entitlementsToken, region, userId)",
    "reAuth(version)",
    "loadAssets()",
    "getAssets()",
    "fetchSkins(language?)",
    "fetchBuddies(language?)",
    "fetchSprays(language?)",
    "fetchPlayerCards(language?)",
    "fetchPlayerTitles(language?)",
    "fetchBundle(bundleId, language?)",
    "fetchVersion()",
    "checkDonator(riotId)",
    "getCurrencies()",
    "generatePaymentSheet({amount, riotId, currencyCode})",
    "checkShop(wishlist: string[])",
    "initBackgroundFetch()",
    "stopBackgroundFetch()",
    "wishlistBgTask()",
    "useUserStore",
    "useWishlistStore",
    "useFeatureStore"
  ]
